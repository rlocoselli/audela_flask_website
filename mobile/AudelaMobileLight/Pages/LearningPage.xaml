<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.LearningPage"
             x:DataType="local:LearningPage"
             Title="Learning">

    <ScrollView BackgroundColor="#F3F7FC">
        <VerticalStackLayout Padding="16" Spacing="10">
            <Label Text="Learning natif"
                   FontSize="24"
             FontAttributes="Bold"
             TextColor="#11263A" />
         <Label Text="Contenu e-learning et quiz natifs"
                   TextColor="#44617D" />

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <Button x:Name="LearningMenuCoursesButton"
                Text="Mes cours"
                ImageSource="tab_learning.svg"
                ContentLayout="Left,6"
                Style="{StaticResource CompactButton}" />
            <Button x:Name="LearningMenuCatalogButton"
                Grid.Column="1"
                Text="Catalogue"
                ImageSource="ic_ai.svg"
                ContentLayout="Left,6"
                Style="{StaticResource CompactButton}" />
            <Button x:Name="LearningMenuSubscriptionsButton"
                Grid.Column="2"
                Text="Abonnements"
                ImageSource="tab_config.svg"
                ContentLayout="Left,6"
                Style="{StaticResource CompactButton}" />
            </Grid>

            <Border StrokeThickness="0" BackgroundColor="#EEF5FF" Padding="12" StrokeShape="RoundRectangle 14">
            <VerticalStackLayout Spacing="8">
                    <Label Text="Abonnement par module"
                   FontAttributes="Bold"
                   TextColor="#12314A" />
                    <Picker x:Name="ModuleSubscriptionPicker"
                        ItemsSource="{Binding SubscriptionModules}"
                        ItemDisplayBinding="{Binding ModuleTitle}"
                        SelectedItem="{Binding SelectedSubscriptionModule}" />
                    <Button Text="S'abonner au module"
                        Style="{StaticResource CompactButton}"
                        Clicked="OnSubscribeModuleClicked" />
                    <Button Text="Gerer mon abonnement"
                    Style="{StaticResource CompactButton}"
                    Clicked="OnManageSubscriptionClicked" />
            </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}" />

            <Label Text="Progression"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#11263A" />

            <CollectionView ItemsSource="{Binding Enrollments}" HeightRequest="220">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:MobileLearningEnrollment">
                        <Border StrokeThickness="0" BackgroundColor="#F1F6FF" Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding ModuleTitle}" FontAttributes="Bold" />
                                <ProgressBar Progress="{Binding ProgressRatio}" />
                                <Label Text="{Binding ProgressLabel}" FontSize="12" TextColor="#4C6D8E" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Contenu"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,8,0,0"
                   TextColor="#11263A" />

            <CollectionView ItemsSource="{Binding Lessons}" HeightRequest="260">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:MobileLearningLesson">
                        <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#F8FBFF" Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding ModuleTitle}" FontSize="12" TextColor="#4C6D8E" />
                                <Label Text="{Binding LessonTitle}" FontAttributes="Bold" TextColor="#17314A" />
                                <Label Text="{Binding Summary}" FontSize="12" MaxLines="3" LineBreakMode="TailTruncation" TextColor="#355E84" />
                                <Button Text="S'abonner a ce module"
                                        Style="{StaticResource CompactButton}"
                                        Clicked="OnSubscribeLessonModuleClicked"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Quiz"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#11263A" />

            <CollectionView ItemsSource="{Binding Quizzes}" HeightRequest="230">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:MobileLearningQuizSummary">
                        <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#F8FBFF" Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#17314A" />
                                <Label Text="{Binding QuizLabel}" FontSize="12" TextColor="#4C6D8E" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
