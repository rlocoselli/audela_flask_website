<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.LearningPage"
             x:DataType="local:LearningPage"
             Title="Learning">

    <Grid RowDefinitions="Auto,*">
        <ScrollView Grid.Row="0">
        <VerticalStackLayout Padding="16" Spacing="10">
            <Label Text="Learning natif"
                   FontSize="24"
                   FontAttributes="Bold" />
            <Label Text="Contenu e-learning + quiz (comme sur le web)"
                   TextColor="#44617D" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Text="Contenu"
                        Clicked="OnShowLearningContentClicked" />
                <Button Grid.Column="1"
                        Text="Quiz"
                        Clicked="OnShowLearningQuizClicked" />
            </Grid>

            <Button Text="Ouvrir page e-learning actuelle"
                    Clicked="OnOpenCurrentLearningWebClicked" />

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}" />

            <CollectionView ItemsSource="{Binding Enrollments}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:MobileLearningEnrollment">
                        <Border StrokeThickness="0" BackgroundColor="#F1F6FF" Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding ModuleTitle}" FontAttributes="Bold" />
                                <ProgressBar Progress="{Binding ProgressRatio}" />
                                <Label Text="{Binding ProgressLabel}" FontSize="12" TextColor="#4C6D8E" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="E-learning Web (contenu + quiz)"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,8,0,0" />
        </VerticalStackLayout>
        </ScrollView>

        <WebView Grid.Row="1"
                 Margin="10,0,10,10"
                 Source="{Binding ActiveLearningUrl}" />
    </Grid>
</ContentPage>
