<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.LearningPage"
             x:DataType="local:LearningPage"
             Title="Learning">

    <ScrollView BackgroundColor="#F2F0FF">
        <VerticalStackLayout Padding="14" Spacing="12">
            <Border StrokeThickness="0" Padding="14" StrokeShape="RoundRectangle 20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4F2CCF" Offset="0.0" />
                        <GradientStop Color="#6A3DDE" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="E-Learning"
                           FontSize="27"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF" />
                    <Label Text="Continue your learning journey"
                           TextColor="#E5D9FF"
                           FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <Button x:Name="LearningMenuCoursesButton"
                Text="In progress"
                ImageSource="tab_learning.svg"
                ContentLayout="Left,6"
                Style="{StaticResource CompactButton}"
                BackgroundColor="#6A3DDE"
                TextColor="White" />
            <Button x:Name="LearningMenuCatalogButton"
                Grid.Column="1"
                Text="Featured"
                ImageSource="ic_ai.svg"
                ContentLayout="Left,6"
                Style="{StaticResource CompactButton}"
                BackgroundColor="#E7DEFF"
                TextColor="#4F2CCF" />
            <Button x:Name="LearningMenuSubscriptionsButton"
                Grid.Column="2"
                Text="Abonnements"
                ImageSource="tab_config.svg"
                ContentLayout="Left,6"
                Style="{StaticResource CompactButton}"
                BackgroundColor="#E7DEFF"
                TextColor="#4F2CCF" />
            </Grid>

            <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
            <VerticalStackLayout Spacing="8">
                    <Label Text="Abonnement par module"
                   FontAttributes="Bold"
                   TextColor="#4023A9" />
                    <Picker x:Name="ModuleSubscriptionPicker"
                        ItemsSource="{Binding SubscriptionModules}"
                        ItemDisplayBinding="{Binding ModuleTitle}"
                        SelectedItem="{Binding SelectedSubscriptionModule}" />
                    <Button Text="S'abonner au module"
                        Style="{StaticResource CompactButton}"
                        BackgroundColor="#6A3DDE"
                        TextColor="White"
                        Clicked="OnSubscribeModuleClicked" />
                    <Button Text="Gerer mon abonnement"
                    Style="{StaticResource CompactButton}"
                    BackgroundColor="#E7DEFF"
                    TextColor="#4F2CCF"
                    Clicked="OnManageSubscriptionClicked" />
            </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}" />

            <Label Text="Progression"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#11263A" />

            <CollectionView ItemsSource="{Binding Enrollments}" HeightRequest="220">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:MobileLearningEnrollment">
                        <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding ModuleTitle}" FontAttributes="Bold" TextColor="#4023A9" />
                                <ProgressBar Progress="{Binding ProgressRatio}" ProgressColor="#6A3DDE" />
                                <Label Text="{Binding ProgressLabel}" FontSize="12" TextColor="#6D5AAB" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Contenu"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,8,0,0"
                   TextColor="#11263A" />

            <CollectionView ItemsSource="{Binding Lessons}" HeightRequest="260">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:MobileLearningLesson">
                        <Border Stroke="#E3DAFF" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding ModuleTitle}" FontSize="12" TextColor="#6D5AAB" />
                                <Label Text="{Binding LessonTitle}" FontAttributes="Bold" TextColor="#4023A9" />
                                <Label Text="{Binding Summary}" FontSize="12" MaxLines="3" LineBreakMode="TailTruncation" TextColor="#6B63A6" />
                                <Button Text="S'abonner a ce module"
                                        Style="{StaticResource CompactButton}"
                                        BackgroundColor="#6A3DDE"
                                        TextColor="White"
                                        Clicked="OnSubscribeLessonModuleClicked"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Quiz"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#11263A" />

            <CollectionView ItemsSource="{Binding Quizzes}" HeightRequest="230">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:MobileLearningQuizSummary">
                        <Border Stroke="#E3DAFF" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#4023A9" />
                                <Label Text="{Binding QuizLabel}" FontSize="12" TextColor="#6D5AAB" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
