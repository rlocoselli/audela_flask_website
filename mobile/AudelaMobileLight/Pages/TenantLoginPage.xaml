<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             x:Class="AudelaMobileLight.Pages.TenantLoginPage"
             x:DataType="local:TenantLoginPage"
             Title="Connexion">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="1,1">
                <GradientStop Color="#081524" Offset="0" />
                <GradientStop Color="#10304D" Offset="0.45" />
                <GradientStop Color="#122A40" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="20,20,20,24" Spacing="14">
                <Image Source="audela_logo_light.svg"
                       HeightRequest="86"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />

                <Label Text="Espace Tenant Premium"
                       FontSize="30"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="White" />
                <Label Text="Connectez-vous a votre organisation AUDELA"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="#B9D5EF" />

                <Border Padding="16"
                        StrokeThickness="0"
                        BackgroundColor="#F4FAFF"
                        StrokeShape="RoundRectangle 22">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Tenant slug (optionnel)"
                               FontSize="12"
                               TextColor="#335977" />
                        <Entry x:Name="TenantSlugEntry"
                               Placeholder="laissez vide pour login web-like"
                               IsEnabled="{Binding IsNotSubmitting}" />

                        <Label Text="Email"
                               FontSize="12"
                               TextColor="#335977" />
                        <Entry x:Name="EmailEntry"
                               Placeholder="you@company.com"
                               Keyboard="Email"
                               IsEnabled="{Binding IsNotSubmitting}" />

                        <Label Text="Mot de passe"
                               FontSize="12"
                               TextColor="#335977" />
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Votre mot de passe"
                               IsPassword="True"
                               IsEnabled="{Binding IsNotSubmitting}" />

                        <Button Text="Se connecter"
                                IsEnabled="{Binding IsNotSubmitting}"
                                Clicked="OnLoginClicked" />
                        <Button Text="Creer un compte"
                                BackgroundColor="#E6F0FC"
                                TextColor="#0D4E8E"
                                IsEnabled="{Binding IsNotSubmitting}"
                                Clicked="OnRegisterClicked" />

                     <Button Text="Continuer avec Google"
                            BackgroundColor="White"
                            TextColor="#1A2D3F"
                            IsEnabled="{Binding IsNotSubmitting}"
                            Clicked="OnGoogleLoginClicked" />

                        <ActivityIndicator IsVisible="{Binding IsSubmitting}"
                                           IsRunning="{Binding IsSubmitting}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
