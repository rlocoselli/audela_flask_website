<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.BiDashboardDetailPage"
             x:DataType="local:BiDashboardDetailPage"
             Title="Dashboard BI">

    <ScrollView BackgroundColor="#EEF3FB">
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{Binding DashboardName}" FontAttributes="Bold" FontSize="24" TextColor="#11263A" />
            <Label Text="{Binding MetaLabel}" FontSize="13" TextColor="#4C6D8E" />

            <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Apercu des graphiques" FontSize="18" FontAttributes="Bold" TextColor="#17314A" />

                    <Label Text="Charge du dashboard" FontSize="13" TextColor="#355E84" />
                    <ProgressBar Progress="{Binding LoadRatio}" ProgressColor="#0A84FF" />

                    <Label Text="Couverture des cartes" FontSize="13" TextColor="#355E84" />
                    <ProgressBar Progress="{Binding CardsCoverageRatio}" ProgressColor="#14A38B" />

                    <Label Text="Fraicheur des donnees" FontSize="13" TextColor="#355E84" />
                    <ProgressBar Progress="{Binding FreshnessRatio}" ProgressColor="#F3A712" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#F8FBFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Details" FontAttributes="Bold" TextColor="#17314A" />
                    <Label Text="{Binding DetailLine1}" TextColor="#355E84" />
                    <Label Text="{Binding DetailLine2}" TextColor="#355E84" />
                    <Label Text="{Binding DetailLine3}" TextColor="#355E84" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" />

            <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Cards (web-like lightweight)" FontAttributes="Bold" FontSize="16" TextColor="#17314A" />

                    <CollectionView ItemsSource="{Binding Cards}" HeightRequest="560">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:MobileBiDashboardCard">
                                <Border Stroke="#E0E8F5" StrokeThickness="1" BackgroundColor="#F9FBFF" Padding="10" Margin="0,0,0,8" StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#163252" />
                                            <Label Grid.Column="1" Text="{Binding VizTypeNormalized}" FontSize="11" TextColor="#5E7392" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Label Text="{Binding SourceName}" FontSize="12" TextColor="#4C6588" />
                                            <Label Grid.Column="1" Text="{Binding PrimaryValue}" FontAttributes="Bold" TextColor="#0A2F8A" />
                                        </Grid>
                                        <Label Text="{Binding SecondaryValue}" FontSize="11" TextColor="#5E7392" />

                                        <Border IsVisible="{Binding IsKpi}" StrokeThickness="0" BackgroundColor="#EAF3FF" Padding="8" StrokeShape="RoundRectangle 10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="KPI" FontSize="10" TextColor="#4D6E95" />
                                                <Label Text="{Binding PrimaryValue}" FontSize="20" FontAttributes="Bold" TextColor="#073B8A" />
                                                <Label Text="{Binding SecondaryValue}" FontSize="11" TextColor="#4D6E95" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <VerticalStackLayout IsVisible="{Binding IsBar}" Spacing="4">
                                            <Label Text="Bar chart" FontSize="11" TextColor="#4D6E95" />
                                            <CollectionView ItemsSource="{Binding Points}" HeightRequest="120">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="model:MobileBiPoint">
                                                        <Grid ColumnDefinitions="72,*,44" ColumnSpacing="8">
                                                            <Label Text="{Binding X}" FontSize="11" TextColor="#446387" LineBreakMode="TailTruncation" />
                                                            <ProgressBar Grid.Column="1" Progress="{Binding Ratio}" ProgressColor="#0A84FF" />
                                                            <Label Grid.Column="2" Text="{Binding Y}" FontSize="11" TextColor="#163252" HorizontalTextAlignment="End" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout IsVisible="{Binding IsLine}" Spacing="4">
                                            <Label Text="Line chart" FontSize="11" TextColor="#4D6E95" />
                                            <CollectionView ItemsSource="{Binding Points}" HeightRequest="120">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="model:MobileBiPoint">
                                                        <Grid ColumnDefinitions="72,*,44" ColumnSpacing="8">
                                                            <Label Text="{Binding X}" FontSize="11" TextColor="#446387" LineBreakMode="TailTruncation" />
                                                            <BoxView Grid.Column="1" HeightRequest="3" CornerRadius="2" BackgroundColor="#14A38B" VerticalOptions="Center" HorizontalOptions="Fill" Opacity="{Binding Ratio}" />
                                                            <Label Grid.Column="2" Text="{Binding Y}" FontSize="11" TextColor="#163252" HorizontalTextAlignment="End" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout IsVisible="{Binding IsPie}" Spacing="4">
                                            <Label Text="Pie chart" FontSize="11" TextColor="#4D6E95" />
                                            <CollectionView ItemsSource="{Binding Points}" HeightRequest="120">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="model:MobileBiPoint">
                                                        <Grid ColumnDefinitions="72,*,44" ColumnSpacing="8">
                                                            <Label Text="{Binding X}" FontSize="11" TextColor="#446387" LineBreakMode="TailTruncation" />
                                                            <ProgressBar Grid.Column="1" Progress="{Binding Ratio}" ProgressColor="#F3A712" />
                                                            <Label Grid.Column="2" Text="{Binding Y}" FontSize="11" TextColor="#163252" HorizontalTextAlignment="End" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout IsVisible="{Binding IsTable}" Spacing="4">
                                            <Label Text="Table preview" FontSize="11" TextColor="#4D6E95" />
                                            <CollectionView ItemsSource="{Binding PreviewRows}" HeightRequest="110">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Label Text="{Binding .}" FontSize="11" TextColor="#32506F" LineBreakMode="TailTruncation" MaxLines="1" />
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>

                                        <Label Text="{Binding TrendLabel}" FontSize="10" TextColor="#6A7FA0" LineBreakMode="TailTruncation" MaxLines="2" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
