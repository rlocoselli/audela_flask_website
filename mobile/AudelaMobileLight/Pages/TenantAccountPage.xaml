<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             x:Class="AudelaMobileLight.Pages.TenantAccountPage"
             x:DataType="local:TenantAccountPage"
             Title="Mon Tenant">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="1,1">
                <GradientStop Color="#081524" Offset="0" />
                <GradientStop Color="#123455" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="20,20,20,24" Spacing="14">
                  <Border Padding="14,10"
                       BackgroundColor="#F4FAFF"
                       StrokeThickness="0"
                       StrokeShape="RoundRectangle 20"
                       HorizontalOptions="Center">
                      <Image Source="audela_logo.png"
                          HeightRequest="90"
                          Aspect="AspectFit"
                          HorizontalOptions="Center" />
                  </Border>

                <Label Text="Mon Espace Tenant"
                       FontSize="30"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="White" />

                <Border BackgroundColor="#F4FAFF"
                        StrokeThickness="0"
                        Padding="16"
                        StrokeShape="RoundRectangle 22">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding TenantNameLabel}"
                               FontAttributes="Bold"
                               FontSize="22"
                               TextColor="#0B1B2F" />
                        <Label Text="{Binding TenantSlugLabel}"
                               FontSize="14"
                               TextColor="#355A79" />
                        <Label Text="{Binding UserLabel}"
                               FontSize="14"
                               TextColor="#355A79" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Ouvrir dashboard web tenant"
                        Clicked="OnOpenTenantDashboardClicked" />

                <Button Text="Se deconnecter"
                        BackgroundColor="#FFE9E9"
                        TextColor="#A23131"
                        Clicked="OnLogoutClicked" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
