<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             x:Class="AudelaMobileLight.Pages.TenantAccountPage"
             x:DataType="local:TenantAccountPage"
             Title="Mon Tenant">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,24" Spacing="12">
            <Label Text="Mon Espace Tenant"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Border BackgroundColor="#F3F8FE"
                    StrokeThickness="0"
                    Padding="14"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding TenantNameLabel}" FontAttributes="Bold" FontSize="20" />
                    <Label Text="{Binding TenantSlugLabel}" FontSize="14" TextColor="#47637D" />
                    <Label Text="{Binding UserLabel}" FontSize="14" TextColor="#47637D" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Ouvrir dashboard web tenant"
                    Clicked="OnOpenTenantDashboardClicked" />

            <Button Text="Se deconnecter"
                    BackgroundColor="#FFE9E9"
                    TextColor="#A23131"
                    Clicked="OnLogoutClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
