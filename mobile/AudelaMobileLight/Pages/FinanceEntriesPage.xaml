<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.FinanceEntriesPage"
             x:DataType="local:FinanceEntriesPage"
             Title="Finance">

    <Grid BackgroundColor="#EEF3FB">
        <ScrollView>
            <VerticalStackLayout x:Name="FinanceRoot" Padding="13" Spacing="10">
                <Border StrokeThickness="0" Padding="13" StrokeShape="RoundRectangle 18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0B2E54" Offset="0.0" />
                            <GradientStop Color="#14697F" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="PageTitleLabel"
                               Text="Saisies finance natives"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#FFFFFF" />
                        <Label x:Name="PageSubtitleLabel"
                               Text="Capture rapide des ecritures et mouvements depuis mobile."
                               TextColor="#CDE9F0"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <Grid x:Name="FinanceMenuGrid" ColumnDefinitions="*,*,*" ColumnSpacing="6">
                    <Button x:Name="DashboardMenuButton" Text="Overview" Clicked="OnDashboardMenuClicked"
                        BackgroundColor="#136A9B" TextColor="White"
                        CornerRadius="22" HeightRequest="38" FontSize="13" FontAttributes="Bold" Padding="4,0" />
                    <Button x:Name="TransactionsMenuButton" Grid.Column="1" Text="Entries" Clicked="OnTransactionsMenuClicked"
                        BackgroundColor="#DDEAF9" TextColor="#12304B"
                        CornerRadius="22" HeightRequest="38" FontSize="13" FontAttributes="Bold" Padding="4,0" />
                    <Button x:Name="QuickEntryMenuButton" Grid.Column="2" Text="+ New" Clicked="OnQuickEntryMenuClicked"
                        BackgroundColor="#DDEAF9" TextColor="#12304B"
                        CornerRadius="22" HeightRequest="38" FontSize="13" FontAttributes="Bold" Padding="4,0" />
                </Grid>

                <ActivityIndicator IsVisible="{Binding IsLoading}"
                                   IsRunning="{Binding IsLoading}" />

                <VerticalStackLayout x:Name="FinanceDashboardSection" IsVisible="{Binding ShowDashboardSection}">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="7">
                        <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Net Income" FontSize="12" TextColor="#4C6D8E" />
                                <Label Text="{Binding DailyNetLabel}" FontAttributes="Bold" FontSize="23" TextColor="#103A63" />
                                <Label Text="{Binding DailyInLabel, StringFormat='Revenue {0}'}" FontSize="11" TextColor="#4C6D8E" />
                                <Label Text="{Binding DailyOutLabel, StringFormat='Expenses {0}'}" FontSize="11" TextColor="#4C6D8E" />
                                <ProgressBar Progress="0.62" ProgressColor="#136A9B" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Operating Margin" FontSize="12" TextColor="#4C6D8E" />
                                <Label Text="{Binding MonthlyNetLabel}" FontAttributes="Bold" FontSize="23" TextColor="#103A63" />
                                <Label Text="{Binding MonthlyInLabel, StringFormat='Revenue {0}'}" FontSize="11" TextColor="#4C6D8E" />
                                <Label Text="{Binding MonthlyOutLabel, StringFormat='Costs {0}'}" FontSize="11" TextColor="#4C6D8E" />
                                <ProgressBar Progress="0.48" ProgressColor="#136A9B" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 14" Margin="0,8,0,0">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="P&amp;L Snapshot" FontAttributes="Bold" TextColor="#13322B" />
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                <Label Text="Revenue" TextColor="#355E54" />
                                <Label Grid.Column="1" Text="{Binding MonthlyInLabel}" TextColor="#13322B" FontAttributes="Bold" />
                                <Label Grid.Row="1" Text="Operating Expenses" TextColor="#355E54" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding MonthlyOutLabel}" TextColor="#13322B" FontAttributes="Bold" />
                                <Label Grid.Row="2" Text="Net Income" TextColor="#355E54" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding MonthlyNetLabel}" TextColor="#136A9B" FontAttributes="Bold" />
                                <Label Grid.Row="3" Text="Cash Health" TextColor="#355E54" />
                                <ProgressBar Grid.Row="3" Grid.Column="1" Progress="0.71" ProgressColor="#136A9B" WidthRequest="110" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="7" Margin="0,8,0,0">
                        <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Expenses by category" FontAttributes="Bold" TextColor="#13322B" FontSize="13" />
                                <CollectionView ItemsSource="{Binding ExpenseCategoryTotals}" HeightRequest="180">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="model:MobileFinanceCategoryTotal">
                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2" Margin="0,0,0,8">
                                                <Label Text="{Binding Category}" FontSize="12" TextColor="#3D4E5F" />
                                                <Label Grid.Column="1" Text="{Binding AmountLabel}" FontAttributes="Bold" FontSize="12" TextColor="#8A2C2C" />
                                                <Label Grid.Row="1" Text="{Binding MetaLabel}" FontSize="11" TextColor="#6D7F92" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Revenue by category" FontAttributes="Bold" TextColor="#13322B" FontSize="13" />
                                <CollectionView ItemsSource="{Binding RevenueCategoryTotals}" HeightRequest="180">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="model:MobileFinanceCategoryTotal">
                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2" Margin="0,0,0,8">
                                                <Label Text="{Binding Category}" FontSize="12" TextColor="#3D4E5F" />
                                                <Label Grid.Column="1" Text="{Binding AmountLabel}" FontAttributes="Bold" FontSize="12" TextColor="#1B6E3E" />
                                                <Label Grid.Row="1" Text="{Binding MetaLabel}" FontSize="11" TextColor="#6D7F92" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="FinanceTransactionsSection" IsVisible="{Binding ShowTransactionsSection}" Spacing="8">

                    <!-- Date filter row -->
                    <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="6,4" StrokeShape="RoundRectangle 14">
                        <Grid ColumnDefinitions="44,*,44" ColumnSpacing="4">
                            <Button x:Name="PrevMonthButton" Text="&#9664;" Clicked="OnPrevMonthClicked"
                                    BackgroundColor="Transparent" TextColor="#136A9B" FontSize="17"
                                    Padding="0" WidthRequest="36" HeightRequest="36" MinimumWidthRequest="36" MinimumHeightRequest="36" />
                            <Label x:Name="DateFilterLabel" Text="" HorizontalOptions="Center" VerticalOptions="Center"
                                   HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                   FontAttributes="Bold" TextColor="#103A63" FontSize="15" />
                            <Button x:Name="NextMonthButton" Grid.Column="2" Text="&#9654;" Clicked="OnNextMonthClicked"
                                    BackgroundColor="Transparent" TextColor="#136A9B" FontSize="17"
                                    Padding="0" WidthRequest="36" HeightRequest="36" MinimumWidthRequest="36" MinimumHeightRequest="36" />
                        </Grid>
                    </Border>

                    <Label x:Name="TransactionCountLabel" Text="" FontSize="12" TextColor="#4C6D8E" Margin="2,0" />

                    <CollectionView x:Name="TransactionCollectionView" ItemsSource="{Binding PagedEntries}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:MobileFinanceEntry">
                                <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF"
                                        Padding="12" StrokeShape="RoundRectangle 14" Margin="0,0,0,8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            NumberOfTapsRequired="2"
                                            Command="{Binding BindingContext.ShowEntryDetailCommand, Source={x:Reference TransactionCollectionView}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                        <Label Text="{Binding Description}" FontAttributes="Bold" TextColor="#12304B" />
                                        <Label Grid.Column="1" Text="{Binding AmountLabel}" TextColor="{Binding AmountColor}" FontAttributes="Bold" />
                                        <Label Grid.Row="1" Text="{Binding Category}" FontSize="12" TextColor="#4C6D8E" />
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Date}" FontSize="12" TextColor="#4C6D8E" />
                                        <Label Grid.Row="2" Grid.ColumnSpan="2" Text="Double-tap for details" FontSize="10" TextColor="#BBCFDF" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Pagination controls -->
                    <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="6,4" StrokeShape="RoundRectangle 14">
                        <Grid ColumnDefinitions="44,*,44" ColumnSpacing="4">
                            <Button x:Name="PrevPageButton" Text="&#9664;" Clicked="OnPrevPageClicked"
                                    BackgroundColor="Transparent" TextColor="#136A9B" FontSize="17"
                                    Padding="0" WidthRequest="36" HeightRequest="36" MinimumWidthRequest="36" MinimumHeightRequest="36" />
                            <Label x:Name="PageLabel" Text="Page 1 / 1" HorizontalOptions="Center" VerticalOptions="Center"
                                   HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                   FontSize="13" TextColor="#103A63" />
                            <Button x:Name="NextPageButton" Grid.Column="2" Text="&#9654;" Clicked="OnNextPageClicked"
                                    BackgroundColor="Transparent" TextColor="#136A9B" FontSize="17"
                                    Padding="0" WidthRequest="36" HeightRequest="36" MinimumWidthRequest="36" MinimumHeightRequest="36" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <VerticalStackLayout x:Name="FinanceQuickEntrySection" IsVisible="{Binding ShowQuickEntrySection}">
                    <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Quick entry" FontAttributes="Bold" TextColor="#13322B" />
                            <Entry x:Name="DescriptionEntry" Placeholder="Description transaction" />
                                <Picker x:Name="CategoryPicker"
                                    ItemsSource="{Binding QuickCategories}"
                                    SelectedItem="{Binding SelectedCategory}"
                                    Title="Categorie" />
                                <Picker x:Name="AccountPicker"
                                    ItemsSource="{Binding Accounts}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedAccount}"
                                    Title="Compte" />
                            <Entry x:Name="AmountEntry" Placeholder="Montant (ex: -120.50 ou 250)" Keyboard="Numeric" />
                            <Button x:Name="VoiceQuickEntryButton"
                                    Text="Dictee vocale"
                                    ImageSource="ic_mic.svg"
                                    ContentLayout="Left,10"
                                    Clicked="OnVoiceQuickEntryClicked"
                                    Style="{StaticResource PremiumRoundedButton}"
                                    BackgroundColor="#245E9B"
                                    TextColor="White" />
                            <Button x:Name="AddQuickEntryButton"
                                    Text="Ajouter"
                                    ImageSource="ic_add.svg"
                                    ContentLayout="Left,10"
                                    Clicked="OnAddQuickEntryClicked"
                                    Style="{StaticResource PremiumRoundedButton}"
                                    BackgroundColor="#136A9B"
                                    TextColor="White" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Button x:Name="FloatingQuickEntryButton"
                Text="Voix + entry"
            ImageSource="ic_mic.svg"
            ContentLayout="Left,8"
                Clicked="OnFloatingQuickEntryClicked"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,16,18"
                Padding="10,6"
                Style="{StaticResource PremiumRoundedButton}"
                BackgroundColor="#136A9B"
                TextColor="White"
                CornerRadius="16" />
    </Grid>
</ContentPage>
