<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.KanbanPage"
             x:DataType="local:KanbanPage"
             Title="Kanban">

    <Grid RowDefinitions="Auto,Auto,Auto,*" BackgroundColor="#F3F7FC">
        <VerticalStackLayout Grid.Row="0" Padding="16,12,16,8" Spacing="8">
            <Label Text="Kanban Projet"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#11263A" />
            <Label Text="Vue native style Jira"
                   TextColor="#44617D" />

            <Border StrokeThickness="0" BackgroundColor="#EAF3FF" Padding="10" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Creer une tache" FontAttributes="Bold" TextColor="#12314A" />
                    <Entry x:Name="NewTitleEntry" Placeholder="Titre" />
                    <Entry x:Name="NewOwnerEntry" Placeholder="Responsable" />
                    <Entry x:Name="NewDescriptionEntry" Placeholder="Description" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Picker x:Name="NewPriorityPicker" Grid.Column="0" Title="Priorite" ItemsSource="{Binding PriorityOptions}" />
                        <Picker x:Name="NewColumnPicker" Grid.Column="1" Title="Colonne" ItemsSource="{Binding ColumnOptions}" />
                        <Entry x:Name="NewDueDateEntry" Grid.Column="2" Placeholder="Due date" />
                    </Grid>
                    <Button Text="Creer tache" ImageSource="ic_add.svg" ContentLayout="Left,10" Clicked="OnCreateTaskClicked" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0" BackgroundColor="#FFF8EC" Padding="10" StrokeShape="RoundRectangle 12" IsVisible="{Binding IsEditPanelVisible}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Modifier la tache (clic carte)" FontAttributes="Bold" TextColor="#603A00" />
                    <Label Text="{Binding SelectedTaskIdLabel}" FontSize="12" TextColor="#7B5C2F" />
                    <Entry x:Name="EditTitleEntry" Placeholder="Titre" Text="{Binding SelectedTaskTitle}" />
                    <Entry x:Name="EditOwnerEntry" Placeholder="Responsable" Text="{Binding SelectedTaskOwner}" />
                    <Entry x:Name="EditDescriptionEntry" Placeholder="Description" Text="{Binding SelectedTaskDescription}" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Picker x:Name="EditPriorityPicker" Grid.Column="0" ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding SelectedTaskPriority}" />
                        <Picker x:Name="EditColumnPicker" Grid.Column="1" ItemsSource="{Binding ColumnOptions}" SelectedItem="{Binding SelectedTaskColumn}" />
                        <Entry x:Name="EditDueDateEntry" Grid.Column="2" Placeholder="Due date" Text="{Binding SelectedTaskDueDate}" />
                    </Grid>
                    <Button Text="Enregistrer modifications" ImageSource="ic_edit.svg" ContentLayout="Left,10" Clicked="OnSaveTaskChangesClicked" BackgroundColor="#C26B00" TextColor="White" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <ActivityIndicator Grid.Row="1"
                           Margin="0,8,0,0"
                           IsVisible="{Binding IsLoading}"
                           IsRunning="{Binding IsLoading}" />

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Columns}"
                        ItemsLayout="HorizontalList"
                        Margin="12,0,12,12">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:MobileKanbanColumn">
                    <Border WidthRequest="286"
                            StrokeThickness="0"
                            BackgroundColor="#FFFFFF"
                            Padding="12"
                            Margin="0,0,8,0"
                            StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <DropGestureRecognizer Drop="OnColumnDrop" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Key}" FontAttributes="Bold" TextTransform="Uppercase" TextColor="#11263A" />
                            <Label Text="{Binding Count, StringFormat='{}Items: {0}'}"
                                   FontSize="12"
                                   TextColor="#4C6D8E" />

                            <CollectionView ItemsSource="{Binding Items}" HeightRequest="420">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="model:MobileKanbanItem">
                                        <Border StrokeThickness="0"
                                                BackgroundColor="#EEF5FF"
                                                Padding="10"
                                                Margin="0,0,0,6"
                                                StrokeShape="RoundRectangle 10">
                                            <Border.GestureRecognizers>
                                                <DragGestureRecognizer DragStarting="OnCardDragStarting" />
                                                <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="OnCardTapped" />
                                                <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnCardDoubleTapped" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#17314A" />
                                                <Label Text="{Binding Owner}" FontSize="12" TextColor="#4C6D8E" />
                                                <Label Text="{Binding Priority, StringFormat='{}Priority: {0}'}" FontSize="11" TextColor="#355E84" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
