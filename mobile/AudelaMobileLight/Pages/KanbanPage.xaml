<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.KanbanPage"
             x:DataType="local:KanbanPage"
             Title="Kanban">

    <Grid RowDefinitions="Auto,Auto,*" BackgroundColor="#EEF3FB">
        <Border Grid.Row="0" StrokeThickness="0" Padding="14" StrokeShape="RoundRectangle 0,0,20,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7A3F00" Offset="0.0" />
                    <GradientStop Color="#B15C08" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <VerticalStackLayout x:Name="KanbanHeaderSection" Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Text="Kanban"
                           FontSize="27"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF" />
                    <Button Grid.Column="1"
                            Text="Search"
                            Style="{StaticResource CompactButton}"
                            BackgroundColor="#CC7A2A"
                            TextColor="#FFFFFF" />
                    <Button Grid.Column="2"
                            Text="Filter"
                            Style="{StaticResource CompactButton}"
                            BackgroundColor="#CC7A2A"
                            TextColor="#FFFFFF" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Button Text="Add task"
                            ImageSource="ic_add.svg"
                            ContentLayout="Left,8"
                            BackgroundColor="#FFFFFF"
                            TextColor="#8A4300"
                            Style="{StaticResource CompactButton}"
                            Clicked="OnOpenCreateTaskScreenClicked" />
                    <Label Grid.Column="1"
                           Text="Tap card to edit. Drag card to move between columns."
                           VerticalTextAlignment="Center"
                           FontSize="12"
                           TextColor="#F8E3CF" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <ActivityIndicator Grid.Row="1"
                           Margin="0,8,0,0"
                           IsVisible="{Binding IsLoading}"
                           IsRunning="{Binding IsLoading}" />

        <CollectionView x:Name="KanbanBoardCollection" Grid.Row="2"
                        ItemsSource="{Binding Columns}"
                        ItemsLayout="HorizontalList"
                VerticalScrollBarVisibility="Always"
                        Margin="12,0,12,12">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:MobileKanbanColumn">
                    <Border WidthRequest="286"
                            Stroke="#D8E5F3"
                            StrokeThickness="1"
                            BackgroundColor="#F9FBFF"
                            Padding="12"
                            Margin="0,0,8,0"
                            StrokeShape="RoundRectangle 14">
                        <Border.GestureRecognizers>
                            <DropGestureRecognizer Drop="OnColumnDrop" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Key}" FontAttributes="Bold" TextTransform="Uppercase" TextColor="#7C4100" />
                                <Border Grid.Column="1" BackgroundColor="#F8E2CC" StrokeThickness="0" Padding="8,3" StrokeShape="RoundRectangle 10">
                                    <Label Text="{Binding Count}" TextColor="#7C4100" FontSize="11" FontAttributes="Bold" />
                                </Border>
                            </Grid>
                            <Label Text="{Binding Count, StringFormat='{}Tasks: {0}'}"
                                   FontSize="12"
                                   TextColor="#8F6843" />

                            <CollectionView ItemsSource="{Binding Items}" HeightRequest="560" VerticalScrollBarVisibility="Always">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="model:MobileKanbanItem">
                                        <Border StrokeThickness="0"
                                                BackgroundColor="#FFFFFF"
                                                Padding="10"
                                                Margin="0,0,0,6"
                                                Stroke="#E7EEF9"
                                                StrokeShape="RoundRectangle 12">
                                            <Border.GestureRecognizers>
                                                <DragGestureRecognizer DragStarting="OnCardDragStarting" />
                                                <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="OnCardTapped" />
                                                <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnCardDoubleTapped" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#6C3A08" />
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                    <BoxView WidthRequest="7" HeightRequest="7" CornerRadius="4" VerticalOptions="Center" BackgroundColor="#A85A12" />
                                                    <Label Grid.Column="1" Text="{Binding Owner}" FontSize="12" TextColor="#8F6843" />
                                                </Grid>
                                                <Label Text="{Binding Priority, StringFormat='{}Priority: {0}'}" FontSize="11" TextColor="#A85A12" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
