<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.KanbanPage"
             x:DataType="local:KanbanPage"
             Title="Kanban">

    <Grid RowDefinitions="Auto,Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="16,12,16,8" Spacing="8">
            <Label Text="Kanban Projet"
                   FontSize="24"
                   FontAttributes="Bold" />
            <Label Text="Vue web style Jira + resume mobile"
                   TextColor="#44617D" />
            <Button Text="Ouvrir Kanban web complet"
                    Clicked="OnOpenProjectWebClicked" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Columns}"
                        ItemsLayout="HorizontalList"
                        HeightRequest="120"
                        Margin="12,0,12,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:MobileKanbanColumn">
                    <Border WidthRequest="130"
                            StrokeThickness="0"
                            BackgroundColor="#F8FAFF"
                            Padding="10"
                            Margin="0,0,8,0"
                            StrokeShape="RoundRectangle 10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Key}" FontAttributes="Bold" TextTransform="Uppercase" />
                            <Label Text="{Binding Count, StringFormat='{}Items: {0}'}"
                                   FontSize="12"
                                   TextColor="#4C6D8E" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <WebView Grid.Row="2"
                 Margin="10,0,10,10"
                 Source="{Binding ProjectKanbanUrl}" />
    </Grid>
</ContentPage>
