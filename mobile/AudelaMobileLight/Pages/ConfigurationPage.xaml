<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             x:Class="AudelaMobileLight.Pages.ConfigurationPage"
             x:DataType="local:ConfigurationPage"
             Title="Configuration">

    <ScrollView BackgroundColor="#EEF3FB">
        <VerticalStackLayout Padding="16" Spacing="12">
            <Border Stroke="#D8E5F3" StrokeThickness="1" Padding="16" StrokeShape="RoundRectangle 22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A1C33" Offset="0.0" />
                        <GradientStop Color="#0B74D1" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="ConfigTitleLabel"
                           Text="Configuration"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF" />
                    <Label x:Name="NativeModeLabel"
                           Text="Mode natif actif: BI, Kanban, Finance et Learning utilisent des composants natifs."
                           TextColor="#D7EAFF" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="14" StrokeShape="RoundRectangle 18">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LanguageLabel"
                           Text="Langue"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#17314A" />
                    <Picker x:Name="LanguagePicker"
                            ItemsSource="{Binding LanguageDisplayValues}"
                            SelectedItem="{Binding SelectedLanguageDisplay}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="14" StrokeShape="RoundRectangle 18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="AiToolbarLabel"
                               Text="Show AI toolbar"
                               FontAttributes="Bold"
                               FontSize="14"
                               TextColor="#17314A" />
                        <Label x:Name="AiToolbarHintLabel"
                               Text="Show/hide BI and AI actions on dashboard."
                               FontSize="12"
                               TextColor="#44617D" />
                    </VerticalStackLayout>
                    <Switch x:Name="AiToolbarSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"
                            Toggled="OnAiToolbarToggled" />
                </Grid>
            </Border>

            <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="14" StrokeShape="RoundRectangle 18">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="AiRuntimeSectionLabel"
                           Text="AI runtime"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#17314A" />

                    <Label x:Name="AiProviderLabel"
                           Text="Provider"
                           FontSize="12"
                           TextColor="#44617D" />
                    <Picker x:Name="AiProviderPicker"
                            ItemsSource="{Binding AiProviderValues}"
                            SelectedItem="{Binding SelectedAiProvider}" />

                    <Label x:Name="AiModelLabel"
                           Text="Model"
                           FontSize="12"
                           TextColor="#44617D" />
                    <Entry x:Name="AiModelEntry"
                           Text="{Binding AiModelText}"
                           Placeholder="example: gpt-4o-mini or mistral-small-latest" />

                    <Button x:Name="SaveAiRuntimeButton"
                            Text="Save AI model"
                            Style="{StaticResource IconActionButton}"
                            BackgroundColor="#E8F1FB"
                            TextColor="#12304B"
                            Clicked="OnSaveAiRuntimeClicked" />

                    <Label x:Name="AiRuntimeStatusLabel"
                           Text="{Binding AiRuntimeStatus, StringFormat='Current: {0}'}"
                           FontSize="12"
                           TextColor="#355E84" />
                </VerticalStackLayout>
            </Border>

            <Button x:Name="TenantAccountButton"
                    Text="Mon compte tenant"
                    ImageSource="tab_config.svg"
                    ContentLayout="Left,10"
                    Style="{StaticResource IconActionButton}"
                    BackgroundColor="#E8F1FB"
                    TextColor="#12304B"
                    Clicked="OnOpenTenantAccountClicked" />

            <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 18">
                <Label x:Name="OAuthInfoLabel"
                       Text="Seule exception web: redirection Google OAuth pendant l'authentification."
                       TextColor="#44617D" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
