<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             x:Class="AudelaMobileLight.Pages.TenantRegisterPage"
             x:DataType="local:TenantRegisterPage"
             Title="Inscription">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="1,1">
                <GradientStop Color="#081524" Offset="0" />
                <GradientStop Color="#123455" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="20,20,20,24" Spacing="14">
                  <Image Source="audela_logo_light.svg"
                      HeightRequest="86"
                      Aspect="AspectFit"
                      HorizontalOptions="Center" />

                <Label Text="Creation de compte"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="White" />
                <Label Text="Experience premium AUDELA, rapide et securisee"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="#BBD8F2" />

                <Border Padding="16"
                        StrokeThickness="0"
                        BackgroundColor="#F4FAFF"
                        StrokeShape="RoundRectangle 22">
                    <VerticalStackLayout Spacing="10">
                        <Entry x:Name="TenantNameEntry"
                               Placeholder="Nom organisation"
                               IsEnabled="{Binding IsNotSubmitting}" />

                        <Entry x:Name="EmailEntry"
                               Placeholder="Email"
                               Keyboard="Email"
                               IsEnabled="{Binding IsNotSubmitting}" />

                        <Entry x:Name="PasswordEntry"
                               Placeholder="Mot de passe"
                               IsPassword="True"
                               IsEnabled="{Binding IsNotSubmitting}" />

                        <Entry x:Name="PasswordConfirmEntry"
                               Placeholder="Confirmez le mot de passe"
                               IsPassword="True"
                               IsEnabled="{Binding IsNotSubmitting}" />

                        <Button Text="Creer mon tenant"
                                IsEnabled="{Binding IsNotSubmitting}"
                                Clicked="OnRegisterClicked" />

                        <ActivityIndicator IsVisible="{Binding IsSubmitting}"
                                           IsRunning="{Binding IsSubmitting}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
