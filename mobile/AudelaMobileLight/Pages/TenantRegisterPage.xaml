<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudelaMobileLight.Pages.TenantRegisterPage"
             Title="Register Tenant">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,24" Spacing="12">
            <Label Text="Inscription Tenant"
                   FontSize="28"
                   FontAttributes="Bold" />
            <Label Text="Creation de compte comme la page web tenant."
                   FontSize="14"
                   TextColor="#47637D" />

            <Entry x:Name="TenantNameEntry"
                   Placeholder="Nom organisation" />

            <Entry x:Name="EmailEntry"
                   Placeholder="Email"
                   Keyboard="Email" />

            <Entry x:Name="PasswordEntry"
                   Placeholder="Password"
                   IsPassword="True" />

            <Entry x:Name="PasswordConfirmEntry"
                   Placeholder="Confirm password"
                   IsPassword="True" />

            <Button Text="Creer mon tenant"
                    Clicked="OnRegisterClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
