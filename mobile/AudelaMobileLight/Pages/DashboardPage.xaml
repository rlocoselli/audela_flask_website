<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             x:Class="AudelaMobileLight.Pages.DashboardPage"
             x:DataType="local:DashboardPage"
             Title="Dashboards">

    <ScrollView BackgroundColor="#F3F7FC">
        <VerticalStackLayout Padding="16" Spacing="12">
             <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <VerticalStackLayout Spacing="2">
                  <Label Text="BI Dashboard (Natif)"
                      FontSize="24"
                      FontAttributes="Bold"
                      TextColor="#11263A" />
                  <Label Text="Vue mobile BI + assistant AI natif"
                      TextColor="#44617D" />
              </VerticalStackLayout>
              <Button Grid.Column="1"
                   Text="Refresh"
                   ImageSource="ic_refresh.svg"
                   ContentLayout="Left,8"
                   Style="{StaticResource IconActionButton}"
                   BackgroundColor="#0A84FF"
                   Clicked="OnRefreshDashboardClicked" />
             </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                <Border StrokeThickness="0" BackgroundColor="#EDF6FF" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Net finance" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding FinanceNetAmountLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#ECFFF6" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Learning avg" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding LearningProgressLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="#FFF5EB" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Dashboards" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding DashboardCountLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" StrokeThickness="0" BackgroundColor="#F5F0FF" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Runs" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding QueryRunCountLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Graph Finance (Jour)" FontAttributes="Bold" FontSize="16" TextColor="#11263A" />
                    <Label Text="{Binding DailyInLabel, StringFormat='Credits: {0}'}" FontSize="12" TextColor="#2D5B3E" />
                    <ProgressBar Progress="{Binding DailyInRatio}" ProgressColor="#1F8A4D" />
                    <Label Text="{Binding DailyOutLabel, StringFormat='Debits: {0}'}" FontSize="12" TextColor="#8B2C2C" />
                    <ProgressBar Progress="{Binding DailyOutRatio}" ProgressColor="#D64545" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Graph Kanban" FontAttributes="Bold" FontSize="16" TextColor="#11263A" />
                    <Label Text="Backlog" FontSize="12" TextColor="#4C6D8E" />
                    <ProgressBar Progress="{Binding KanbanBacklogRatio}" ProgressColor="#536878" />
                    <Label Text="Todo" FontSize="12" TextColor="#4C6D8E" />
                    <ProgressBar Progress="{Binding KanbanTodoRatio}" ProgressColor="#0A84FF" />
                    <Label Text="Doing" FontSize="12" TextColor="#4C6D8E" />
                    <ProgressBar Progress="{Binding KanbanDoingRatio}" ProgressColor="#F59E0B" />
                    <Label Text="Done" FontSize="12" TextColor="#4C6D8E" />
                    <ProgressBar Progress="{Binding KanbanDoneRatio}" ProgressColor="#1F8A4D" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Kanban global" FontAttributes="Bold" FontSize="18" Margin="0,8,0,0" />
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                <Border StrokeThickness="0" BackgroundColor="#F4F7FB" Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Backlog" FontSize="11" TextColor="#4C6D8E" />
                        <Label Text="{Binding KanbanBacklogLabel}" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#F4F7FB" Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Todo" FontSize="11" TextColor="#4C6D8E" />
                        <Label Text="{Binding KanbanTodoLabel}" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="#F4F7FB" Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Doing" FontSize="11" TextColor="#4C6D8E" />
                        <Label Text="{Binding KanbanDoingLabel}" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="3" StrokeThickness="0" BackgroundColor="#F4F7FB" Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Done" FontSize="11" TextColor="#4C6D8E" />
                        <Label Text="{Binding KanbanDoneLabel}" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Chat AI" FontAttributes="Bold" FontSize="18" TextColor="#11263A" />
                    <Label x:Name="AiSourceLabel"
                           Text="Source des donnees AI"
                           FontSize="12"
                           TextColor="#4C6D8E" />
                    <Picker x:Name="AiSourcePicker"
                            ItemsSource="{Binding AiSourceLabels}"
                            SelectedItem="{Binding SelectedAiSourceLabel}" />
                    <CollectionView HeightRequest="170" ItemsSource="{Binding AiMessages}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0" BackgroundColor="#EEF5FF" Padding="10" Margin="0,0,0,6" StrokeShape="RoundRectangle 10">
                                    <Label Text="{Binding .}" TextColor="#14314A" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Entry x:Name="AiQuestionEntry" Placeholder="Ex: donne moi le resume finance" />
                    <Button x:Name="AskAiButton"
                            Text="Demander a AI"
                            ImageSource="ic_ai.svg"
                            ContentLayout="Left,10"
                            Style="{StaticResource IconActionButton}"
                            Clicked="OnAskAiClicked" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}"
                               Margin="0,6,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
