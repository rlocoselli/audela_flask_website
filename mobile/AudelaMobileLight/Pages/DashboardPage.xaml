<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.DashboardPage"
             x:DataType="local:DashboardPage"
             Title="Dashboards">

    <ScrollView BackgroundColor="#EEF3FB">
        <VerticalStackLayout x:Name="DashboardRoot" Padding="13" Spacing="10">
            <Border x:Name="DashboardHeaderCard" StrokeThickness="0" Padding="13" StrokeShape="RoundRectangle 18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#071A56" Offset="0.0" />
                        <GradientStop Color="#0A2F8A" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid x:Name="DashboardHeaderGrid" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="5">
                    <Label Text="Dashboard"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF" />
                    <Button Grid.Column="1"
                            Text="Refresh"
                            ImageSource="ic_refresh.svg"
                            ContentLayout="Left,6"
                            Clicked="OnRefreshDashboardClicked"
                            BackgroundColor="#2D5CE6"
                            TextColor="#FFFFFF"
                            Style="{StaticResource PremiumRoundedButton}" />
                    <Label Grid.Row="1"
                           Text="Dashboards, query studio, chart gallery et AI chat"
                           TextColor="#BFD0FF"
                           FontSize="12" />
                    <Border Grid.Row="1" Grid.Column="1" StrokeThickness="0" BackgroundColor="#15398E" Padding="8,4" StrokeShape="RoundRectangle 12">
                        <Label Text="Live"
                               TextColor="#D9E5FF"
                               FontAttributes="Bold"
                               FontSize="11"
                               HorizontalTextAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="BiMenuCard" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="8">
                    <Label Text="BI Workspace" FontAttributes="Bold" FontSize="17" TextColor="#0F1F3A" />
                    <Label Text="Professional tools for analysis, SQL and AI workflows." FontSize="12" TextColor="#5E7392" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="7" RowSpacing="7">
                        <Button Text="Dashboards"
                                Style="{StaticResource PremiumRoundedButton}"
                                BackgroundColor="#1E4FBB"
                                Clicked="OnOpenDashboardsHubClicked" />
                        <Button Grid.Column="1"
                                Text="Query Studio"
                                Style="{StaticResource PremiumRoundedButton}"
                                BackgroundColor="#136A9B"
                                Clicked="OnOpenQueryStudioClicked" />
                        <Button Grid.Row="1"
                                Text="Chart Gallery"
                                Style="{StaticResource PremiumRoundedButton}"
                                BackgroundColor="#0A8F77"
                                Clicked="OnOpenChartGalleryClicked" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Text="AI Chat"
                                ImageSource="ic_ai.svg"
                                ContentLayout="Left,10"
                                Style="{StaticResource PremiumRoundedButton}"
                                BackgroundColor="#245E9B"
                                Clicked="OnOpenAiChatClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Grid x:Name="KpiGrid" ColumnDefinitions="*,*" ColumnSpacing="7" RowSpacing="7">
                <Border StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Datasources" FontSize="11" TextColor="#5E7392" />
                        <Label Text="{Binding BiDataSourceCountLabel}" FontSize="24" FontAttributes="Bold" TextColor="#0F1F3A" />
                        <Label Text="connected" FontSize="11" TextColor="#5E7392" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Dashboards" FontSize="11" TextColor="#5E7392" />
                        <Label Text="{Binding DashboardCountLabel}" FontSize="24" FontAttributes="Bold" TextColor="#0F1F3A" />
                        <Label Text="published" FontSize="11" TextColor="#5E7392" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Query Runs" FontSize="11" TextColor="#5E7392" />
                        <Label Text="{Binding QueryRunCountLabel}" FontSize="24" FontAttributes="Bold" TextColor="#0F1F3A" />
                        <ProgressBar Progress="0.72" ProgressColor="#2D5CE6" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Source active" FontSize="11" TextColor="#5E7392" />
                        <Label Text="{Binding ActiveSourceLabel}" FontSize="13" FontAttributes="Bold" TextColor="#0F1F3A" LineBreakMode="TailTruncation" />
                        <ProgressBar Progress="0.55" ProgressColor="#26B36D" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border x:Name="FinanceGraphCard" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Executive Dashboards" FontAttributes="Bold" FontSize="16" TextColor="#0F1F3A" />
                    <CollectionView ItemsSource="{Binding BiDashboards}" HeightRequest="260">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:MobileBiDashboardSummary">
                                <Border Stroke="#E0E8F5" StrokeThickness="1" BackgroundColor="#F9FBFF" Padding="10" Margin="0,0,0,8" StrokeShape="RoundRectangle 12">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="#163252" />
                                        <Label Grid.Column="1" Text="{Binding CardsCount, StringFormat='{}#{0} cards'}" FontSize="11" TextColor="#5E7392" />
                                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Progress="0.68" ProgressColor="#2D5CE6" />
                                        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label Text="{Binding MetaLabel}" FontSize="12" TextColor="#4C6588" VerticalTextAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Text="Open"
                                                    Clicked="OnOpenDashboardClicked"
                                                    CommandParameter="{Binding .}"
                                                    HorizontalOptions="End"
                                                    Style="{StaticResource CompactButton}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="KanbanGraphCard" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Connected Data Sources" FontAttributes="Bold" FontSize="16" TextColor="#0F1F3A" />
                    <CollectionView ItemsSource="{Binding BiDataSources}" HeightRequest="170">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:MobileBiDataSource">
                                <Border Stroke="#E0E8F5" StrokeThickness="1" BackgroundColor="#F9FBFF" Padding="10" Margin="0,0,0,7" StrokeShape="RoundRectangle 12">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" VerticalOptions="Center" BackgroundColor="#2D5CE6" />
                                        <Label Grid.Column="1" Text="{Binding DisplayName}" TextColor="#17314A" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsBiEmptyStateVisible}" Stroke="#D8E3F6" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="11" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="7">
                    <Label Text="BI n'est pas configure pour ce tenant" FontAttributes="Bold" TextColor="#12304B" FontSize="15" />
                    <Label Text="Ajoute au moins une datasource et un dashboard dans la configuration web pour afficher du contenu ici."
                           TextColor="#4C6588"
                           FontSize="12" />
                    <Button Text="Ouvrir configuration"
                            Style="{StaticResource PremiumRoundedButton}"
                            BackgroundColor="#2D5CE6"
                            TextColor="White"
                            Clicked="OnOpenBiSetupClicked" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" Margin="0,6,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
