<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AudelaMobileLight.Pages"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.Pages.DashboardPage"
             x:DataType="local:DashboardPage"
             Title="Dashboards">

    <ScrollView BackgroundColor="#F3F7FC">
           <VerticalStackLayout x:Name="DashboardRoot" Padding="16" Spacing="12">
               <Grid x:Name="DashboardHeaderGrid" ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <VerticalStackLayout Spacing="2">
                  <Label Text="BI Dashboard (Natif)"
                      FontSize="24"
                      FontAttributes="Bold"
                      TextColor="#11263A" />
                  <Label Text="Vue mobile BI + assistant AI natif"
                      TextColor="#44617D" />
              </VerticalStackLayout>
              <Button Grid.Column="1"
                   Text="Refresh"
                   ImageSource="ic_refresh.svg"
                   ContentLayout="Left,8"
                   Style="{StaticResource IconActionButton}"
                   BackgroundColor="#0A84FF"
                   Clicked="OnRefreshDashboardClicked" />
             </Grid>

            <Grid x:Name="KpiGrid" ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                <Border StrokeThickness="0" BackgroundColor="#EDF6FF" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Net finance" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding FinanceNetAmountLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#ECFFF6" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Learning avg" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding LearningProgressLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="#FFF5EB" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Dashboards" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding DashboardCountLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" StrokeThickness="0" BackgroundColor="#F5F0FF" Padding="12" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>
                        <Label Text="Runs" FontSize="12" TextColor="#4C6D8E" />
                        <Label Text="{Binding QueryRunCountLabel}" FontSize="22" FontAttributes="Bold" TextColor="#11263A" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border x:Name="FinanceGraphCard" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Dashboards BI du tenant" FontAttributes="Bold" FontSize="16" TextColor="#11263A" />
                    <CollectionView ItemsSource="{Binding BiDashboards}" HeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:MobileBiDashboardSummary">
                                <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#F8FBFF" Padding="10" Margin="0,0,0,6" StrokeShape="RoundRectangle 10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="#17314A" />
                                        <Label Text="{Binding MetaLabel}" FontSize="12" TextColor="#4C6D8E" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="KanbanGraphCard" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Datasources BI du tenant" FontAttributes="Bold" FontSize="16" TextColor="#11263A" />
                    <CollectionView ItemsSource="{Binding BiDataSources}" HeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:MobileBiDataSource">
                                <Border Stroke="#D8E5F3" StrokeThickness="1" BackgroundColor="#F8FBFF" Padding="10" Margin="0,0,0,6" StrokeShape="RoundRectangle 10">
                                    <Label Text="{Binding DisplayName}" TextColor="#17314A" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="AiCard" StrokeThickness="0" BackgroundColor="#FFFFFF" Padding="12" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Chat AI" FontAttributes="Bold" FontSize="18" TextColor="#11263A" />
                    <Label x:Name="AiSourceLabel"
                           Text="Source des donnees AI"
                           FontSize="12"
                           TextColor="#4C6D8E" />
                    <Picker x:Name="AiSourcePicker"
                            ItemsSource="{Binding BiDataSources}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            SelectedItem="{Binding SelectedBiDataSource}" />
                    <CollectionView HeightRequest="170" ItemsSource="{Binding AiMessages}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:MobileAiChatMessage">
                                <Border StrokeThickness="0" Padding="10" Margin="0,0,0,6" StrokeShape="RoundRectangle 10">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#0A84FF" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsUser}" Value="False">
                                            <Setter Property="BackgroundColor" Value="#EDF2FF" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Text}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="TextColor" Value="#FFFFFF" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsUser}" Value="False">
                                                <Setter Property="TextColor" Value="#10243A" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Entry x:Name="AiQuestionEntry" Placeholder="Ex: donne moi le resume finance" />
                    <Button x:Name="AskAiButton"
                            Text="Demander a AI"
                            ImageSource="ic_ai.svg"
                            ContentLayout="Left,10"
                            Style="{StaticResource IconActionButton}"
                            Clicked="OnAskAiClicked" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}"
                               Margin="0,6,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
