<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:AudelaMobileLight.Models"
             x:Class="AudelaMobileLight.MainPage"
             x:DataType="local:MainPage"
             xmlns:local="clr-namespace:AudelaMobileLight"
             Title="Produits">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="16,12,16,4">
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label Text="{Binding TenantStatusLabel}"
                       FontSize="12"
                       VerticalOptions="Center"
                       TextColor="#365A78" />
                <Button Grid.Column="1"
                        Text="Tenant"
                        Padding="12,6"
                        Clicked="OnTenantButtonClicked" />
            </Grid>

            <Border StrokeThickness="0"
                    Padding="18"
                    StrokeShape="RoundRectangle 24">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1">
                        <GradientStop Color="#0B1B2F" Offset="0.0" />
                        <GradientStop Color="#0A84FF" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="AUDELA"
                               FontSize="13"
                               TextColor="#A7D1FF"
                               TextTransform="Uppercase" />
                        <Label Text="Mobile Light"
                               FontAttributes="Bold"
                               FontSize="30"
                               TextColor="White" />
                        <Label Text="Tous les produits, experience simplifiee."
                               FontSize="14"
                               TextColor="#D7EAFF" />
                    </VerticalStackLayout>

                          <Image Grid.Column="1"
                              Source="audela_logo_light.svg"
                           HeightRequest="68"
                           VerticalOptions="Start"
                           Aspect="AspectFit" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView x:Name="ProductsCollection"
                            Margin="16,2,16,12"
                            ItemsSource="{Binding Products}"
                            SelectionMode="Single"
                            SelectionChanged="OnProductSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:AudelaProduct">
                        <Border Padding="16"
                                Margin="0,0,0,12"
                                StrokeThickness="0"
                                BackgroundColor="#F3F8FE"
                                StrokeShape="RoundRectangle 18">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8">
                                <Label Text="{Binding Title}"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       FontAttributes="Bold"
                                       FontSize="20" />
                                <Border Grid.Row="0"
                                        Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="#E0EEFF"
                                        Padding="8,4"
                                        StrokeShape="RoundRectangle 10">
                                    <Label Text="{Binding Tag}"
                                           FontSize="11"
                                           TextColor="#0A5FB8"
                                           TextTransform="Uppercase" />
                                </Border>
                                <Label Text="{Binding Subtitle}"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       FontSize="14"
                                       TextColor="#1E3E5F" />
                                <Label Text="{Binding Summary}"
                                       Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       FontSize="13"
                                       MaxLines="3"
                                       LineBreakMode="TailTruncation"
                                       TextColor="#35546F" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
